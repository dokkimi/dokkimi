{
  "name": "@dokkimi/config",
  "version": "0.4.2",
  "license": "Elastic-2.0",
  "description": "Centralized configuration for Dokkimi platform",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
