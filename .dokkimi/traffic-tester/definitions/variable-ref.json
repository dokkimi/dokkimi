{
  "name": "variable-ref",
  "description": "Demonstrates $ref for variables — shared variable files referenced from definition and test levels",
  "config": {
    "timeoutSeconds": 120
  },
  "items": [
    {
      "$ref": "../shared/service-a.yaml"
    },
    {
      "$ref": "../shared/service-b.json"
    },
    {
      "$ref": "../shared/postgres.yaml"
    },
    {
      "$ref": "../shared/redis.json"
    }
  ],
  "variables": {
    "$ref": "../shared/db-vars.json"
  },
  "tests": [
    {
      "name": "DB query using $ref connection strings",
      "variables": {
        "expectedName": "Alice"
      },
      "steps": [
        {
          "name": "pgConnStr comes from shared/db-vars.json via definition $ref",
          "action": {
            "type": "dbQuery",
            "database": "postgres-db",
            "query": "SELECT * FROM users WHERE name = '{{expectedName}}' LIMIT 1"
          },
          "assertions": [
            {
              "assertions": [
                {
                  "path": "success",
                  "operator": "eq",
                  "value": true
                },
                {
                  "path": "data[0].name",
                  "operator": "eq",
                  "value": "{{expectedName}}"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "name": "Test-level $ref with multi-file merge",
      "variables": {
        "$ref": ["../shared/db-vars.json", "../shared/test-users.json"],
        "testRunLabel": "multi-ref-test"
      },
      "steps": [
        {
          "name": "Uses variables from both db-vars.json and test-users.json",
          "action": {
            "type": "dbQuery",
            "database": "postgres-db",
            "query": "SELECT * FROM users WHERE name = '{{defaultUserName}}' OR email = '{{secondUserEmail}}'"
          },
          "assertions": [
            {
              "assertions": [
                {
                  "path": "success",
                  "operator": "eq",
                  "value": true
                }
              ]
            }
          ]
        },
        {
          "name": "Forward user to service-b using shared connection config",
          "action": {
            "type": "httpRequest",
            "method": "POST",
            "url": "service-a/forward-user",
            "headers": {
              "Content-Type": "application/json"
            },
            "body": {
              "requests": [
                {
                  "baseURL": "http://service-b",
                  "url": "/receive-user",
                  "method": "POST",
                  "data": {
                    "response": {
                      "value": {
                        "received": true,
                        "userName": "{{defaultUserName}}",
                        "label": "{{testRunLabel}}"
                      }
                    }
                  }
                }
              ]
            }
          },
          "assertions": [
            {
              "assertions": [
                {
                  "path": "response.status",
                  "operator": "eq",
                  "value": 200
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
