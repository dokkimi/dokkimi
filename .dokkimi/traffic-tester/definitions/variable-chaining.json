{
  "name": "variable-chaining",
  "description": "Demonstrates chaining variables across steps — extracting from DB queries and using in HTTP requests and assertions",
  "config": {
    "timeoutSeconds": 120
  },
  "items": [
    {
      "$ref": "../shared/service-a.yaml"
    },
    {
      "$ref": "../shared/service-b.json"
    },
    {
      "$ref": "../shared/service-c.yaml"
    },
    {
      "$ref": "../shared/postgres.yaml"
    },
    {
      "$ref": "../shared/redis.json"
    }
  ],
  "tests": [
    {
      "name": "Query user from DB, forward to service, and validate",
      "variables": {
        "pgConnStr": "postgresql://dokkimi:dokkimi@postgres-db:5432/dokkimi",
        "expectedName": "Alice"
      },
      "steps": [
        {
          "name": "Look up Alice from the database",
          "action": {
            "type": "dbQuery",
            "database": "postgres-db",
            "query": "SELECT * FROM users WHERE name = '{{expectedName}}' LIMIT 1"
          },
          "extract": {
            "userId": "$.data[0].id",
            "userEmail": "$.data[0].email",
            "userName": "$.data[0].name"
          },
          "assertions": [
            {
              "assertions": [
                {
                  "path": "success",
                  "operator": "eq",
                  "value": true
                },
                {
                  "path": "data[0].name",
                  "operator": "eq",
                  "value": "{{expectedName}}"
                },
                {
                  "path": "data[0].email",
                  "operator": "exists"
                }
              ]
            }
          ]
        },
        {
          "name": "Send extracted user data to service-b via service-a",
          "action": {
            "type": "httpRequest",
            "method": "POST",
            "url": "service-a/forward-user",
            "headers": {
              "Content-Type": "application/json"
            },
            "body": {
              "requests": [
                {
                  "baseURL": "http://service-b",
                  "url": "/receive-user",
                  "method": "POST",
                  "data": {
                    "response": {
                      "value": {
                        "received": true,
                        "userId": "{{userId}}",
                        "userName": "{{userName}}",
                        "userEmail": "{{userEmail}}"
                      }
                    }
                  }
                }
              ]
            }
          },
          "assertions": [
            {
              "assertions": [
                {
                  "path": "response.status",
                  "operator": "eq",
                  "value": 200
                },
                {
                  "path": "response.body.results[0].received",
                  "operator": "eq",
                  "value": true
                },
                {
                  "path": "response.body.results[0].userName",
                  "operator": "eq",
                  "value": "{{expectedName}}"
                },
                {
                  "path": "response.body.results[0].userEmail",
                  "operator": "eq",
                  "value": "{{userEmail}}"
                }
              ]
            },
            {
              "match": {
                "origin": "service-a",
                "method": "POST",
                "url": "service-b/receive-user"
              },
              "count": {
                "operator": "eq",
                "value": 1
              },
              "assertions": [
                {
                  "path": "request.body.response.value.userName",
                  "operator": "eq",
                  "value": "{{expectedName}}"
                },
                {
                  "path": "response.status",
                  "operator": "eq",
                  "value": 200
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "name": "Insert user, cache in Redis, then verify both stores match",
      "variables": {
        "pgConnStr": "postgresql://dokkimi:dokkimi@postgres-db:5432/dokkimi",
        "redisConnStr": "redis://:dokkimi@redis-db:6379",
        "newUserName": "Diana",
        "newUserEmail": "diana@example.com"
      },
      "steps": [
        {
          "name": "Insert a new user into Postgres",
          "action": {
            "type": "httpRequest",
            "method": "POST",
            "url": "service-a/insert-user",
            "headers": {
              "Content-Type": "application/json"
            },
            "body": {
              "queries": [
                {
                  "databaseType": "postgres",
                  "connectionString": "{{pgConnStr}}",
                  "command": "INSERT INTO users (email, name) VALUES ('{{newUserEmail}}', '{{newUserName}}') RETURNING *"
                }
              ]
            }
          },
          "extract": {
            "insertedId": "$.body.queryResults[0][0].result[0].id"
          },
          "assertions": [
            {
              "assertions": [
                {
                  "path": "response.status",
                  "operator": "eq",
                  "value": 200
                },
                {
                  "path": "response.body.queryResults[0][0].result[0].name",
                  "operator": "eq",
                  "value": "{{newUserName}}"
                }
              ]
            }
          ]
        },
        {
          "name": "Cache the new user ID in Redis",
          "action": {
            "type": "httpRequest",
            "method": "POST",
            "url": "service-a/cache-user",
            "headers": {
              "Content-Type": "application/json"
            },
            "body": {
              "queries": [
                {
                  "databaseType": "redis",
                  "connectionString": "{{redisConnStr}}",
                  "command": "SET user:{{newUserEmail}} {{insertedId}}"
                }
              ]
            }
          },
          "assertions": [
            {
              "assertions": [
                {
                  "path": "response.status",
                  "operator": "eq",
                  "value": 200
                },
                {
                  "path": "response.body.queryResults[0][0].result",
                  "operator": "eq",
                  "value": "OK"
                }
              ]
            }
          ]
        },
        {
          "name": "Read back from Redis and verify it matches the Postgres ID",
          "action": {
            "type": "parallel",
            "actions": [
              {
                "type": "httpRequest",
                "method": "POST",
                "url": "service-a/read-cache",
                "headers": {
                  "Content-Type": "application/json"
                },
                "body": {
                  "queries": [
                    {
                      "databaseType": "redis",
                      "connectionString": "{{redisConnStr}}",
                      "command": "GET user:{{newUserEmail}}"
                    }
                  ]
                }
              },
              {
                "type": "dbQuery",
                "database": "postgres-db",
                "query": "SELECT * FROM users WHERE id = {{insertedId}}"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "Chain DB lookup through multiple services with logging",
      "variables": {
        "pgConnStr": "postgresql://dokkimi:dokkimi@postgres-db:5432/dokkimi",
        "lookupEmail": "bob@example.com"
      },
      "steps": [
        {
          "name": "Look up Bob by email",
          "action": {
            "type": "dbQuery",
            "database": "postgres-db",
            "query": "SELECT * FROM users WHERE email = '{{lookupEmail}}'"
          },
          "extract": {
            "bobId": "$.data[0].id",
            "bobName": "$.data[0].name"
          },
          "assertions": [
            {
              "assertions": [
                {
                  "path": "success",
                  "operator": "eq",
                  "value": true
                },
                {
                  "path": "data[0].email",
                  "operator": "eq",
                  "value": "{{lookupEmail}}"
                }
              ]
            }
          ]
        },
        {
          "name": "Service-a forwards Bob's data through service-b to service-c",
          "action": {
            "type": "httpRequest",
            "method": "POST",
            "url": "service-a/chain-user",
            "headers": {
              "Content-Type": "application/json"
            },
            "body": {
              "preRequestLogs": [
                "CHAIN: Forwarding user {{bobName}} (id={{bobId}})"
              ],
              "requests": [
                {
                  "baseURL": "http://service-b",
                  "url": "/relay",
                  "method": "POST",
                  "data": {
                    "requests": [
                      {
                        "baseURL": "http://service-c",
                        "url": "/final",
                        "method": "POST",
                        "data": {
                          "response": {
                            "value": {
                              "finalUserId": "{{bobId}}",
                              "finalUserName": "{{bobName}}",
                              "processedBy": "service-c"
                            }
                          }
                        }
                      }
                    ]
                  }
                }
              ],
              "postRequestLogs": ["CHAIN: Complete for user {{bobName}}"]
            }
          },
          "extract": {
            "finalName": "$.body.results[0].results[0].finalUserName"
          },
          "assertions": [
            {
              "assertions": [
                {
                  "path": "response.status",
                  "operator": "eq",
                  "value": 200
                },
                {
                  "path": "response.body.results[0].results[0].finalUserId",
                  "operator": "eq",
                  "value": "{{bobId}}"
                },
                {
                  "path": "response.body.results[0].results[0].finalUserName",
                  "operator": "eq",
                  "value": "{{bobName}}"
                },
                {
                  "path": "response.body.results[0].results[0].processedBy",
                  "operator": "eq",
                  "value": "service-c"
                }
              ]
            },
            {
              "match": {
                "origin": "service-a",
                "method": "POST",
                "url": "service-b/relay"
              },
              "count": {
                "operator": "eq",
                "value": 1
              }
            },
            {
              "match": {
                "origin": "service-b",
                "method": "POST",
                "url": "service-c/final"
              },
              "count": {
                "operator": "eq",
                "value": 1
              },
              "assertions": [
                {
                  "path": "response.body.finalUserName",
                  "operator": "eq",
                  "value": "{{bobName}}"
                }
              ]
            },
            {
              "service": "service-a",
              "consoleAssertions": [
                {
                  "message": {
                    "operator": "contains",
                    "value": "CHAIN: Forwarding user {{bobName}}"
                  },
                  "count": {
                    "operator": "gte",
                    "value": 1
                  }
                },
                {
                  "message": {
                    "operator": "contains",
                    "value": "CHAIN: Complete for user {{bobName}}"
                  },
                  "count": {
                    "operator": "gte",
                    "value": 1
                  }
                }
              ]
            }
          ]
        },
        {
          "name": "Verify extracted variable matches original DB value",
          "action": {
            "type": "dbQuery",
            "database": "postgres-db",
            "query": "SELECT * FROM users WHERE name = '{{finalName}}'"
          },
          "assertions": [
            {
              "assertions": [
                {
                  "path": "success",
                  "operator": "eq",
                  "value": true
                },
                {
                  "path": "data[0].email",
                  "operator": "eq",
                  "value": "{{lookupEmail}}"
                },
                {
                  "path": "data[0].name",
                  "operator": "eq",
                  "value": "{{bobName}}"
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
