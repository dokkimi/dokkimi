{
  "name": "assertion-scopes-and-counts",
  "description": "Coverage for assertionScope (first, last, any, all), count operators (gt, gte, lt, lte), and repeated inter-service calls",
  "config": {
    "timeoutSeconds": 120
  },
  "items": [
    {
      "$ref": "../shared/service-a.yaml"
    },
    {
      "$ref": "../shared/service-b.json"
    },
    {
      "$ref": "../shared/service-c.yaml"
    }
  ],
  "tests": [
    {
      "name": "Multiple calls with assertionScope: first",
      "steps": [
        {
          "name": "Service-a makes three sequential calls to service-b",
          "action": {
            "type": "httpRequest",
            "method": "POST",
            "url": "service-a/multi-call",
            "headers": {
              "Content-Type": "application/json"
            },
            "body": {
              "requests": [
                {
                  "baseURL": "http://service-b",
                  "url": "/batch",
                  "method": "POST",
                  "data": {
                    "response": {
                      "value": {
                        "index": 1,
                        "batch": "first"
                      }
                    }
                  }
                },
                {
                  "baseURL": "http://service-b",
                  "url": "/batch",
                  "method": "POST",
                  "data": {
                    "response": {
                      "value": {
                        "index": 2,
                        "batch": "second"
                      }
                    }
                  }
                },
                {
                  "baseURL": "http://service-b",
                  "url": "/batch",
                  "method": "POST",
                  "data": {
                    "response": {
                      "value": {
                        "index": 3,
                        "batch": "third"
                      }
                    }
                  }
                }
              ]
            }
          },
          "assertions": [
            {
              "assertions": [
                {
                  "path": "$.response.status",
                  "operator": "eq",
                  "value": 200
                },
                {
                  "path": "$.response.body.results",
                  "operator": "length",
                  "value": 3
                }
              ]
            },
            {
              "match": {
                "origin": "service-a",
                "method": "POST",
                "url": "service-b/batch"
              },
              "count": {
                "operator": "eq",
                "value": 3
              },
              "assertionScope": "first",
              "assertions": [
                {
                  "path": "$.response.body.index",
                  "operator": "in",
                  "value": [1, 2, 3]
                },
                {
                  "path": "$.response.body.batch",
                  "operator": "in",
                  "value": ["first", "second", "third"]
                },
                {
                  "path": "$.response.status",
                  "operator": "eq",
                  "value": 200
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "name": "Multiple calls with assertionScope: any (verifies specific value exists)",
      "steps": [
        {
          "name": "Service-a makes three calls, assert on last",
          "action": {
            "type": "httpRequest",
            "method": "POST",
            "url": "service-a/multi-call",
            "headers": {
              "Content-Type": "application/json"
            },
            "body": {
              "requests": [
                {
                  "baseURL": "http://service-b",
                  "url": "/sequence",
                  "method": "POST",
                  "data": {
                    "response": {
                      "value": {
                        "seq": 1
                      }
                    }
                  }
                },
                {
                  "baseURL": "http://service-b",
                  "url": "/sequence",
                  "method": "POST",
                  "data": {
                    "response": {
                      "value": {
                        "seq": 2
                      }
                    }
                  }
                },
                {
                  "baseURL": "http://service-b",
                  "url": "/sequence",
                  "method": "POST",
                  "data": {
                    "response": {
                      "value": {
                        "seq": 3
                      }
                    }
                  }
                }
              ]
            }
          },
          "assertions": [
            {
              "match": {
                "origin": "service-a",
                "method": "POST",
                "url": "service-b/sequence"
              },
              "count": {
                "operator": "gte",
                "value": 3
              },
              "assertionScope": "any",
              "assertions": [
                {
                  "path": "$.response.body.seq",
                  "operator": "eq",
                  "value": 3
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "name": "Multiple calls with assertionScope: last (validates last captured entry)",
      "steps": [
        {
          "name": "Service-a makes two calls in one action, assert last has valid response",
          "action": {
            "type": "httpRequest",
            "method": "POST",
            "url": "service-a/multi-call",
            "headers": {
              "Content-Type": "application/json"
            },
            "body": {
              "requests": [
                {
                  "baseURL": "http://service-b",
                  "url": "/ordered",
                  "method": "POST",
                  "data": {
                    "response": {
                      "value": {
                        "step": "first"
                      }
                    }
                  }
                },
                {
                  "baseURL": "http://service-b",
                  "url": "/ordered",
                  "method": "POST",
                  "data": {
                    "response": {
                      "value": {
                        "step": "second"
                      }
                    }
                  }
                }
              ]
            }
          },
          "assertions": [
            {
              "match": {
                "origin": "service-a",
                "method": "POST",
                "url": "service-b/ordered"
              },
              "count": {
                "operator": "eq",
                "value": 2
              },
              "assertionScope": "last",
              "assertions": [
                {
                  "path": "$.response.status",
                  "operator": "eq",
                  "value": 200
                },
                {
                  "path": "$.response.body.step",
                  "operator": "in",
                  "value": ["first", "second"]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "name": "Multiple calls with assertionScope: any",
      "steps": [
        {
          "name": "Service-a makes calls with varying responses, at least one matches",
          "action": {
            "type": "httpRequest",
            "method": "POST",
            "url": "service-a/multi-call",
            "headers": {
              "Content-Type": "application/json"
            },
            "body": {
              "requests": [
                {
                  "baseURL": "http://service-b",
                  "url": "/varied",
                  "method": "POST",
                  "data": {
                    "response": {
                      "value": {
                        "role": "reader"
                      }
                    }
                  }
                },
                {
                  "baseURL": "http://service-b",
                  "url": "/varied",
                  "method": "POST",
                  "data": {
                    "response": {
                      "value": {
                        "role": "admin"
                      }
                    }
                  }
                },
                {
                  "baseURL": "http://service-b",
                  "url": "/varied",
                  "method": "POST",
                  "data": {
                    "response": {
                      "value": {
                        "role": "editor"
                      }
                    }
                  }
                }
              ]
            }
          },
          "assertions": [
            {
              "match": {
                "origin": "service-a",
                "method": "POST",
                "url": "service-b/varied"
              },
              "count": {
                "operator": "gt",
                "value": 2
              },
              "assertionScope": "any",
              "assertions": [
                {
                  "path": "$.response.body.role",
                  "operator": "eq",
                  "value": "admin"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "name": "Count assertions with different operators",
      "steps": [
        {
          "name": "Service-a fans out to service-b and service-c",
          "action": {
            "type": "httpRequest",
            "method": "POST",
            "url": "service-a/fan-out",
            "headers": {
              "Content-Type": "application/json"
            },
            "body": {
              "requests": [
                {
                  "baseURL": "http://service-b",
                  "url": "/counted",
                  "method": "POST",
                  "data": {
                    "response": {
                      "value": {
                        "ok": true
                      }
                    }
                  }
                },
                {
                  "baseURL": "http://service-c",
                  "url": "/counted",
                  "method": "POST",
                  "data": {
                    "response": {
                      "value": {
                        "ok": true
                      }
                    }
                  }
                }
              ]
            }
          },
          "assertions": [
            {
              "match": {
                "origin": "service-a",
                "url": "service-b/counted"
              },
              "count": {
                "operator": "gte",
                "value": 1
              }
            },
            {
              "match": {
                "origin": "service-a",
                "url": "service-c/counted"
              },
              "count": {
                "operator": "lte",
                "value": 1
              }
            },
            {
              "match": {
                "origin": "service-a"
              },
              "count": {
                "operator": "gte",
                "value": 2
              }
            },
            {
              "match": {
                "origin": "service-b"
              },
              "count": {
                "operator": "eq",
                "value": 0
              }
            }
          ]
        }
      ]
    }
  ]
}
