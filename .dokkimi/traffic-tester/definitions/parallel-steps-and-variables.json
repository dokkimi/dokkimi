{
  "name": "parallel-steps-and-variables",
  "description": "Coverage for parallel step execution within groups, multi-step variable extraction, stopOnFailure: false, and complex multi-group workflows",
  "config": {
    "timeoutSeconds": 120
  },
  "items": [
    {
      "$ref": "../shared/service-a.yaml"
    },
    {
      "$ref": "../shared/service-b.json"
    },
    {
      "$ref": "../shared/service-c.yaml"
    },
    {
      "$ref": "../shared/postgres.yaml"
    },
    {
      "$ref": "../shared/redis.json"
    }
  ],
  "tests": [
    {
      "name": "Parallel health checks across all services",
      "steps": [
        {
          "name": "Health check service-a",
          "action": {
            "type": "parallel",
            "actions": [
              {
                "type": "httpRequest",
                "method": "GET",
                "url": "service-a/health"
              },
              {
                "type": "httpRequest",
                "method": "GET",
                "url": "service-b/health"
              },
              {
                "type": "httpRequest",
                "method": "GET",
                "url": "service-c/health"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "Parallel DB queries with variable extraction then sequential verification",
      "variables": {
        "pgConnStr": "postgresql://dokkimi:dokkimi@postgres-db:5432/dokkimi",
        "redisConnStr": "redis://:dokkimi@redis-db:6379"
      },
      "steps": [
        {
          "name": "Query Alice from Postgres",
          "action": {
            "type": "dbQuery",
            "database": "postgres-db",
            "query": "SELECT * FROM users WHERE name = 'Alice' LIMIT 1"
          },
          "extract": {
            "aliceId": "$.data[0].id",
            "aliceEmail": "$.data[0].email"
          },
          "assertions": [
            {
              "assertions": [
                {
                  "path": "success",
                  "operator": "eq",
                  "value": true
                },
                {
                  "path": "data[0].name",
                  "operator": "eq",
                  "value": "Alice"
                }
              ]
            }
          ]
        },
        {
          "name": "Query Bob from Postgres",
          "action": {
            "type": "dbQuery",
            "database": "postgres-db",
            "query": "SELECT * FROM users WHERE name = 'Bob' LIMIT 1"
          },
          "extract": {
            "bobId": "$.data[0].id",
            "bobEmail": "$.data[0].email"
          },
          "assertions": [
            {
              "assertions": [
                {
                  "path": "success",
                  "operator": "eq",
                  "value": true
                },
                {
                  "path": "data[0].name",
                  "operator": "eq",
                  "value": "Bob"
                }
              ]
            }
          ]
        },
        {
          "name": "Cache both users in Redis",
          "action": {
            "type": "httpRequest",
            "method": "POST",
            "url": "service-a/cache-users",
            "headers": {
              "Content-Type": "application/json"
            },
            "body": {
              "queries": [
                {
                  "databaseType": "redis",
                  "connectionString": "{{redisConnStr}}",
                  "command": "SET user:alice:id {{aliceId}}"
                },
                {
                  "databaseType": "redis",
                  "connectionString": "{{redisConnStr}}",
                  "command": "SET user:bob:id {{bobId}}"
                }
              ]
            }
          },
          "assertions": [
            {
              "assertions": [
                {
                  "path": "response.status",
                  "operator": "eq",
                  "value": 200
                }
              ]
            }
          ]
        },
        {
          "name": "Read Alice from Redis",
          "action": {
            "type": "httpRequest",
            "method": "POST",
            "url": "service-a/read-cache",
            "headers": {
              "Content-Type": "application/json"
            },
            "body": {
              "queries": [
                {
                  "databaseType": "redis",
                  "connectionString": "{{redisConnStr}}",
                  "command": "GET user:alice:id"
                }
              ]
            }
          },
          "assertions": [
            {
              "assertions": [
                {
                  "path": "response.status",
                  "operator": "eq",
                  "value": 200
                },
                {
                  "path": "response.body.queryResults[0][0].result",
                  "operator": "eq",
                  "value": "{{aliceId}}"
                }
              ]
            }
          ]
        },
        {
          "name": "Read Bob from Redis",
          "action": {
            "type": "httpRequest",
            "method": "POST",
            "url": "service-a/read-cache",
            "headers": {
              "Content-Type": "application/json"
            },
            "body": {
              "queries": [
                {
                  "databaseType": "redis",
                  "connectionString": "{{redisConnStr}}",
                  "command": "GET user:bob:id"
                }
              ]
            }
          },
          "assertions": [
            {
              "assertions": [
                {
                  "path": "response.status",
                  "operator": "eq",
                  "value": 200
                },
                {
                  "path": "response.body.queryResults[0][0].result",
                  "operator": "eq",
                  "value": "{{bobId}}"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "name": "stopOnFailure false allows subsequent steps to run",
      "stopOnFailure": false,
      "steps": [
        {
          "name": "First step succeeds",
          "action": {
            "type": "httpRequest",
            "method": "GET",
            "url": "service-a/health"
          },
          "assertions": [
            {
              "assertions": [
                {
                  "path": "response.status",
                  "operator": "eq",
                  "value": 200
                }
              ]
            }
          ]
        },
        {
          "name": "Second step also runs even if first had failures",
          "action": {
            "type": "httpRequest",
            "method": "POST",
            "url": "service-a/continue",
            "headers": {
              "Content-Type": "application/json"
            },
            "body": {
              "response": {
                "value": {
                  "continued": true
                }
              }
            }
          },
          "assertions": [
            {
              "assertions": [
                {
                  "path": "response.status",
                  "operator": "eq",
                  "value": 200
                },
                {
                  "path": "response.body.continued",
                  "operator": "eq",
                  "value": true
                }
              ]
            }
          ]
        },
        {
          "name": "Third step verifies entire chain ran",
          "action": {
            "type": "dbQuery",
            "database": "postgres-db",
            "query": "SELECT 1 as alive"
          },
          "assertions": [
            {
              "assertions": [
                {
                  "path": "success",
                  "operator": "eq",
                  "value": true
                },
                {
                  "path": "data[0].alive",
                  "operator": "eq",
                  "value": 1
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "name": "Multi-group workflow with wait step",
      "variables": {
        "pgConnStr": "postgresql://dokkimi:dokkimi@postgres-db:5432/dokkimi"
      },
      "steps": [
        {
          "name": "Insert a new user via service",
          "action": {
            "type": "httpRequest",
            "method": "POST",
            "url": "service-a/insert-user",
            "headers": {
              "Content-Type": "application/json"
            },
            "body": {
              "queries": [
                {
                  "databaseType": "postgres",
                  "connectionString": "{{pgConnStr}}",
                  "command": "INSERT INTO users (email, name) VALUES ('eve@example.com', 'Eve') RETURNING *"
                }
              ]
            }
          },
          "extract": {
            "eveId": "$.body.queryResults[0][0].result[0].id"
          },
          "assertions": [
            {
              "assertions": [
                {
                  "path": "response.status",
                  "operator": "eq",
                  "value": 200
                }
              ]
            }
          ]
        },
        {
          "name": "Wait for data to propagate",
          "action": {
            "type": "wait",
            "durationMs": 500
          }
        },
        {
          "name": "Verify the user was persisted via direct DB query",
          "action": {
            "type": "parallel",
            "actions": [
              {
                "type": "dbQuery",
                "database": "postgres-db",
                "query": "SELECT * FROM users WHERE id = {{eveId}}"
              },
              {
                "type": "dbQuery",
                "database": "postgres-db",
                "query": "SELECT COUNT(*) as total FROM users"
              }
            ]
          }
        }
      ]
    }
  ]
}
