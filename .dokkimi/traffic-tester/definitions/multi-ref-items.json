{
  "name": "multi-ref-items",
  "description": "Demonstrates multi-ref $ref for items — composing a service from a base template + staging overrides",
  "config": {
    "timeoutSeconds": 60
  },
  "items": [
    {
      "$ref": ["../shared/service-a.yaml", "../shared/staging-overrides.json"],
      "env": [
        "...$ref.env",
        {
          "name": "TEST_LABEL",
          "value": "multi-ref"
        }
      ]
    },
    {
      "$ref": "../shared/postgres.yaml"
    }
  ],
  "variables": {
    "$ref": "../shared/db-vars.json",
    "testLabel": "multi-ref-demo"
  },
  "tests": [
    {
      "name": "Service-a with staging overrides responds",
      "steps": [
        {
          "name": "Health check on service-a (staging image with debug env)",
          "action": {
            "type": "httpRequest",
            "method": "GET",
            "url": "service-a/health"
          },
          "assertions": [
            {
              "assertions": [
                {
                  "path": "response.status",
                  "operator": "eq",
                  "value": 200
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
