{
  "name": "inter-service-traffic",
  "description": "Inter-service HTTP communication — forwarding, multi-hop chaining, fan-out, and header propagation",
  "config": {
    "timeoutSeconds": 120
  },
  "items": [
    {
      "$ref": "../shared/service-a.yaml"
    },
    {
      "$ref": "../shared/service-b.json"
    },
    {
      "$ref": "../shared/service-c.yaml"
    }
  ],
  "tests": [
    {
      "name": "Service-to-service forwarding (A -> B)",
      "steps": [
        {
          "name": "Service-a forwards request to service-b",
          "action": {
            "type": "httpRequest",
            "method": "POST",
            "url": "service-a/forward",
            "headers": {
              "Content-Type": "application/json"
            },
            "body": {
              "requests": [
                {
                  "baseURL": "http://service-b",
                  "url": "/forwarded",
                  "method": "POST",
                  "data": {
                    "response": {
                      "status": 200,
                      "value": {
                        "message": "hello from service-b"
                      }
                    }
                  }
                }
              ]
            }
          },
          "assertions": [
            {
              "assertions": [
                {
                  "path": "$.response.status",
                  "operator": "eq",
                  "value": 200
                },
                {
                  "path": "$.response.body.results[0].message",
                  "operator": "eq",
                  "value": "hello from service-b"
                }
              ]
            },
            {
              "match": {
                "origin": "service-a",
                "method": "POST",
                "url": "service-b/forwarded"
              },
              "count": {
                "operator": "eq",
                "value": 1
              },
              "assertions": [
                {
                  "path": "$.response.status",
                  "operator": "eq",
                  "value": 200
                },
                {
                  "path": "$.response.body.message",
                  "operator": "eq",
                  "value": "hello from service-b"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "name": "Multi-hop chaining (A -> B -> C)",
      "steps": [
        {
          "name": "Service-a calls service-b which calls service-c",
          "action": {
            "type": "httpRequest",
            "method": "POST",
            "url": "service-a/chain",
            "headers": {
              "Content-Type": "application/json"
            },
            "body": {
              "requests": [
                {
                  "baseURL": "http://service-b",
                  "url": "/hop2",
                  "method": "POST",
                  "data": {
                    "requests": [
                      {
                        "baseURL": "http://service-c",
                        "url": "/hop3",
                        "method": "POST",
                        "data": {
                          "response": {
                            "status": 200,
                            "value": {
                              "origin": "service-c",
                              "hop": 3
                            }
                          }
                        }
                      }
                    ]
                  }
                }
              ]
            }
          },
          "assertions": [
            {
              "assertions": [
                {
                  "path": "$.response.status",
                  "operator": "eq",
                  "value": 200
                },
                {
                  "path": "$.response.body.results[0].results[0].origin",
                  "operator": "eq",
                  "value": "service-c"
                },
                {
                  "path": "$.response.body.results[0].results[0].hop",
                  "operator": "eq",
                  "value": 3
                }
              ]
            },
            {
              "match": {
                "origin": "service-a",
                "method": "POST",
                "url": "service-b/hop2"
              },
              "count": {
                "operator": "eq",
                "value": 1
              },
              "assertions": [
                {
                  "path": "$.response.status",
                  "operator": "eq",
                  "value": 200
                }
              ]
            },
            {
              "match": {
                "origin": "service-b",
                "method": "POST",
                "url": "service-c/hop3"
              },
              "count": {
                "operator": "eq",
                "value": 1
              },
              "assertions": [
                {
                  "path": "$.response.status",
                  "operator": "eq",
                  "value": 200
                },
                {
                  "path": "$.response.body.origin",
                  "operator": "eq",
                  "value": "service-c"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "name": "Parallel fan-out (A -> B + C)",
      "steps": [
        {
          "name": "Service-a fans out to service-b and service-c in parallel",
          "action": {
            "type": "httpRequest",
            "method": "POST",
            "url": "service-a/fan-out",
            "headers": {
              "Content-Type": "application/json"
            },
            "body": {
              "requests": [
                {
                  "baseURL": "http://service-b",
                  "url": "/handle-b",
                  "method": "POST",
                  "data": {
                    "response": {
                      "value": {
                        "handler": "service-b"
                      }
                    }
                  }
                },
                {
                  "baseURL": "http://service-c",
                  "url": "/handle-c",
                  "method": "POST",
                  "data": {
                    "response": {
                      "value": {
                        "handler": "service-c"
                      }
                    }
                  }
                }
              ]
            }
          },
          "assertions": [
            {
              "assertions": [
                {
                  "path": "$.response.status",
                  "operator": "eq",
                  "value": 200
                },
                {
                  "path": "$.response.body.results",
                  "operator": "length",
                  "value": 2
                }
              ]
            },
            {
              "match": {
                "origin": "service-a",
                "method": "POST",
                "url": "service-b/handle-b"
              },
              "count": {
                "operator": "eq",
                "value": 1
              }
            },
            {
              "match": {
                "origin": "service-a",
                "method": "POST",
                "url": "service-c/handle-c"
              },
              "count": {
                "operator": "eq",
                "value": 1
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Custom headers forwarded between services",
      "steps": [
        {
          "name": "Service-a forwards custom headers to service-b",
          "action": {
            "type": "httpRequest",
            "method": "POST",
            "url": "service-a/header-forward",
            "headers": {
              "Content-Type": "application/json"
            },
            "body": {
              "requests": [
                {
                  "baseURL": "http://service-b",
                  "url": "/check-headers",
                  "method": "POST",
                  "headers": {
                    "X-Trace-Id": "trace-abc-123",
                    "X-Custom-Auth": "Bearer test-token"
                  },
                  "data": {
                    "response": {
                      "value": {
                        "received": true
                      }
                    }
                  }
                }
              ]
            }
          },
          "assertions": [
            {
              "assertions": [
                {
                  "path": "$.response.status",
                  "operator": "eq",
                  "value": 200
                }
              ]
            },
            {
              "match": {
                "origin": "service-a",
                "method": "POST",
                "url": "service-b/check-headers"
              },
              "count": {
                "operator": "eq",
                "value": 1
              },
              "assertions": [
                {
                  "path": "$.request.headers.x-trace-id",
                  "operator": "eq",
                  "value": "trace-abc-123"
                },
                {
                  "path": "$.request.headers.x-custom-auth",
                  "operator": "eq",
                  "value": "Bearer test-token"
                },
                {
                  "path": "$.response.status",
                  "operator": "eq",
                  "value": 200
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "name": "No inter-service traffic when no requests are made",
      "steps": [
        {
          "name": "Service-a responds without making any outbound calls",
          "action": {
            "type": "httpRequest",
            "method": "POST",
            "url": "service-a/isolated",
            "headers": {
              "Content-Type": "application/json"
            },
            "body": {
              "response": {
                "value": {
                  "isolated": true
                }
              }
            }
          },
          "assertions": [
            {
              "assertions": [
                {
                  "path": "$.response.status",
                  "operator": "eq",
                  "value": 200
                },
                {
                  "path": "$.response.body.isolated",
                  "operator": "eq",
                  "value": true
                }
              ]
            },
            {
              "match": {
                "origin": "service-a"
              },
              "count": {
                "operator": "eq",
                "value": 0
              }
            }
          ]
        }
      ]
    }
  ]
}
