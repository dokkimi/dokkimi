{
  "name": "mock-body-matching",
  "description": "Mock body matching — same endpoint returns different responses based on request body content (substring and regex)",
  "config": {
    "timeoutSeconds": 120
  },
  "items": [
    {
      "$ref": "../shared/service-a.yaml"
    },
    {
      "type": "MOCK",
      "name": "mock-llm-classify",
      "mockMethod": "POST",
      "mockTarget": "api.llm-provider.com",
      "mockPath": "/v1/chat/completions",
      "mockRequestBodyContains": "classify this ticket",
      "mockResponseStatus": 200,
      "mockResponseHeaders": {
        "Content-Type": "application/json"
      },
      "mockResponseBody": {
        "id": "chatcmpl-001",
        "choices": [
          {
            "message": {
              "role": "assistant",
              "content": "billing"
            }
          }
        ]
      }
    },
    {
      "type": "MOCK",
      "name": "mock-llm-extract",
      "mockMethod": "POST",
      "mockTarget": "api.llm-provider.com",
      "mockPath": "/v1/chat/completions",
      "mockRequestBodyContains": "extract entities",
      "mockResponseStatus": 200,
      "mockResponseHeaders": {
        "Content-Type": "application/json"
      },
      "mockResponseBody": {
        "id": "chatcmpl-002",
        "choices": [
          {
            "message": {
              "role": "assistant",
              "content": "{\"people\": [\"Alice\"], \"places\": [\"NYC\"]}"
            }
          }
        ]
      }
    },
    {
      "type": "MOCK",
      "name": "mock-llm-fallback",
      "mockMethod": "POST",
      "mockTarget": "api.llm-provider.com",
      "mockPath": "/v1/chat/completions",
      "mockResponseStatus": 200,
      "mockResponseHeaders": {
        "Content-Type": "application/json"
      },
      "mockResponseBody": {
        "id": "chatcmpl-fallback",
        "choices": [
          {
            "message": {
              "role": "assistant",
              "content": "I don't understand."
            }
          }
        ]
      }
    },
    {
      "type": "MOCK",
      "name": "mock-graphql-users",
      "mockMethod": "POST",
      "mockTarget": "api.graphql-provider.com",
      "mockPath": "/graphql",
      "mockRequestBodyContains": "getUsers",
      "mockResponseStatus": 200,
      "mockResponseHeaders": {
        "Content-Type": "application/json"
      },
      "mockResponseBody": {
        "data": {
          "users": [
            {
              "id": "1",
              "name": "Alice"
            }
          ]
        }
      }
    },
    {
      "type": "MOCK",
      "name": "mock-graphql-orders",
      "mockMethod": "POST",
      "mockTarget": "api.graphql-provider.com",
      "mockPath": "/graphql",
      "mockRequestBodyContains": "getOrders",
      "mockResponseStatus": 200,
      "mockResponseHeaders": {
        "Content-Type": "application/json"
      },
      "mockResponseBody": {
        "data": {
          "orders": [
            {
              "id": "ord-1",
              "total": 99.99
            }
          ]
        }
      }
    },
    {
      "type": "MOCK",
      "name": "mock-regex-tool-call",
      "mockMethod": "POST",
      "mockTarget": "api.llm-provider.com",
      "mockPath": "/v1/tool-calls",
      "mockRequestBodyMatches": "\"tool\":\\s*\"search_database\"",
      "mockResponseStatus": 200,
      "mockResponseHeaders": {
        "Content-Type": "application/json"
      },
      "mockResponseBody": {
        "result": "found 3 matching records"
      }
    },
    {
      "type": "MOCK",
      "name": "mock-regex-tool-call-send-email",
      "mockMethod": "POST",
      "mockTarget": "api.llm-provider.com",
      "mockPath": "/v1/tool-calls",
      "mockRequestBodyMatches": "\"tool\":\\s*\"send_email\"",
      "mockResponseStatus": 200,
      "mockResponseHeaders": {
        "Content-Type": "application/json"
      },
      "mockResponseBody": {
        "result": "email sent successfully"
      }
    }
  ],
  "tests": [
    {
      "name": "LLM prompt routing — different prompts get different responses",
      "steps": [
        {
          "name": "{{prompt.label}} prompt matches {{prompt.label}} mock",
          "forEach": {
            "items": [
              {
                "label": "classify",
                "content": "classify this ticket: printer not working",
                "expectedId": "chatcmpl-001",
                "expectedContent": "billing"
              },
              {
                "label": "extract",
                "content": "extract entities from: Alice lives in NYC",
                "expectedId": "chatcmpl-002",
                "expectedContent": "Alice"
              },
              {
                "label": "fallback",
                "content": "tell me a joke",
                "expectedId": "chatcmpl-fallback",
                "expectedContent": "I don't understand."
              }
            ],
            "as": "prompt",
            "action": {
              "type": "httpRequest",
              "method": "POST",
              "url": "service-a/external-call",
              "headers": {
                "Content-Type": "application/json"
              },
              "body": {
                "requests": [
                  {
                    "baseURL": "http://api.llm-provider.com",
                    "url": "/v1/chat/completions",
                    "method": "POST",
                    "data": {
                      "model": "gpt-4o",
                      "messages": [
                        {
                          "role": "user",
                          "content": "{{prompt.content}}"
                        }
                      ]
                    }
                  }
                ]
              }
            },
            "assertions": [
              {
                "assertions": [
                  {
                    "path": "$.response.status",
                    "operator": "eq",
                    "value": 200
                  },
                  {
                    "path": "$.response.body.results[0].id",
                    "operator": "eq",
                    "value": "{{prompt.expectedId}}"
                  },
                  {
                    "path": "$.response.body.results[0].choices[0].message.content",
                    "operator": "contains",
                    "value": "{{prompt.expectedContent}}"
                  }
                ]
              }
            ]
          }
        }
      ]
    },
    {
      "name": "GraphQL — same endpoint, different queries",
      "steps": [
        {
          "name": "getUsers query returns users",
          "action": {
            "type": "httpRequest",
            "method": "POST",
            "url": "service-a/external-call",
            "headers": {
              "Content-Type": "application/json"
            },
            "body": {
              "requests": [
                {
                  "baseURL": "http://api.graphql-provider.com",
                  "url": "/graphql",
                  "method": "POST",
                  "data": {
                    "query": "query { getUsers { id name } }"
                  }
                }
              ]
            }
          },
          "assertions": [
            {
              "assertions": [
                {
                  "path": "$.response.status",
                  "operator": "eq",
                  "value": 200
                },
                {
                  "path": "$.response.body.results[0].data.users[0].name",
                  "operator": "eq",
                  "value": "Alice"
                }
              ]
            }
          ]
        },
        {
          "name": "getOrders query returns orders",
          "action": {
            "type": "httpRequest",
            "method": "POST",
            "url": "service-a/external-call",
            "headers": {
              "Content-Type": "application/json"
            },
            "body": {
              "requests": [
                {
                  "baseURL": "http://api.graphql-provider.com",
                  "url": "/graphql",
                  "method": "POST",
                  "data": {
                    "query": "query { getOrders { id total } }"
                  }
                }
              ]
            }
          },
          "assertions": [
            {
              "assertions": [
                {
                  "path": "$.response.status",
                  "operator": "eq",
                  "value": 200
                },
                {
                  "path": "$.response.body.results[0].data.orders[0].id",
                  "operator": "eq",
                  "value": "ord-1"
                },
                {
                  "path": "$.response.body.results[0].data.orders[0].total",
                  "operator": "eq",
                  "value": 99.99
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "name": "Regex body matching — tool call routing",
      "steps": [
        {
          "name": "{{tool.name}} tool call matches regex",
          "forEach": {
            "items": [
              {
                "name": "search_database",
                "args": { "query": "order #1234" },
                "expectedResult": "found 3 matching records"
              },
              {
                "name": "send_email",
                "args": { "to": "alice@example.com", "subject": "Hello" },
                "expectedResult": "email sent successfully"
              }
            ],
            "as": "tool",
            "action": {
              "type": "httpRequest",
              "method": "POST",
              "url": "service-a/external-call",
              "headers": {
                "Content-Type": "application/json"
              },
              "body": {
                "requests": [
                  {
                    "baseURL": "http://api.llm-provider.com",
                    "url": "/v1/tool-calls",
                    "method": "POST",
                    "data": {
                      "tool": "{{tool.name}}",
                      "args": "{{tool.args}}"
                    }
                  }
                ]
              }
            },
            "assertions": [
              {
                "assertions": [
                  {
                    "path": "$.response.status",
                    "operator": "eq",
                    "value": 200
                  },
                  {
                    "path": "$.response.body.results[0].result",
                    "operator": "eq",
                    "value": "{{tool.expectedResult}}"
                  }
                ]
              }
            ]
          }
        }
      ]
    },
    {
      "name": "Body matching case insensitivity",
      "steps": [
        {
          "name": "Mixed-case prompt still matches classify mock",
          "action": {
            "type": "httpRequest",
            "method": "POST",
            "url": "service-a/external-call",
            "headers": {
              "Content-Type": "application/json"
            },
            "body": {
              "requests": [
                {
                  "baseURL": "http://api.llm-provider.com",
                  "url": "/v1/chat/completions",
                  "method": "POST",
                  "data": {
                    "model": "gpt-4o",
                    "messages": [
                      {
                        "role": "user",
                        "content": "CLASSIFY THIS TICKET: server down"
                      }
                    ]
                  }
                }
              ]
            }
          },
          "assertions": [
            {
              "assertions": [
                {
                  "path": "$.response.status",
                  "operator": "eq",
                  "value": 200
                },
                {
                  "path": "$.response.body.results[0].id",
                  "operator": "eq",
                  "value": "chatcmpl-001"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "name": "Traffic assertions verify body-matched mocks",
      "steps": [
        {
          "name": "All three LLM calls hit the same endpoint",
          "action": {
            "type": "httpRequest",
            "method": "POST",
            "url": "service-a/external-call",
            "headers": {
              "Content-Type": "application/json"
            },
            "body": {
              "requests": [
                {
                  "baseURL": "http://api.llm-provider.com",
                  "url": "/v1/chat/completions",
                  "method": "POST",
                  "data": {
                    "messages": [
                      {
                        "role": "user",
                        "content": "classify this ticket: bug report"
                      }
                    ]
                  }
                },
                {
                  "baseURL": "http://api.llm-provider.com",
                  "url": "/v1/chat/completions",
                  "method": "POST",
                  "data": {
                    "messages": [
                      {
                        "role": "user",
                        "content": "extract entities from this text"
                      }
                    ]
                  }
                },
                {
                  "baseURL": "http://api.llm-provider.com",
                  "url": "/v1/chat/completions",
                  "method": "POST",
                  "data": {
                    "messages": [
                      {
                        "role": "user",
                        "content": "something else entirely"
                      }
                    ]
                  }
                }
              ]
            }
          },
          "assertions": [
            {
              "assertions": [
                {
                  "path": "$.response.status",
                  "operator": "eq",
                  "value": 200
                },
                {
                  "path": "$.response.body.results[0].id",
                  "operator": "eq",
                  "value": "chatcmpl-001"
                },
                {
                  "path": "$.response.body.results[1].id",
                  "operator": "eq",
                  "value": "chatcmpl-002"
                },
                {
                  "path": "$.response.body.results[2].id",
                  "operator": "eq",
                  "value": "chatcmpl-fallback"
                }
              ]
            },
            {
              "match": {
                "path": "$.traffic",
                "where": [
                  {
                    "path": "$$.origin",
                    "operator": "eq",
                    "value": "service-a"
                  },
                  {
                    "path": "$$.request.method",
                    "operator": "eq",
                    "value": "POST"
                  },
                  {
                    "path": "$$.request.url",
                    "operator": "contains",
                    "value": "api.llm-provider.com/v1/chat/completions"
                  }
                ],
                "count": {
                  "operator": "eq",
                  "value": 3
                }
              }
            }
          ]
        }
      ]
    }
  ]
}
