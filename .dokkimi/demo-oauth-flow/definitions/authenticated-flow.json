{
  "name": "authenticated-flow",
  "description": "Tests authenticated endpoints using the session token from the OAuth callback flow",
  "items": [
    { "$ref": "../shared/api-service.json" },
    {
      "$ref": "../shared/postgres-db.json",
      "initFilePath": "../init-files/schema.sql"
    },
    { "$ref": "../shared/mock-oauth-token.json" },
    { "$ref": "../shared/mock-oauth-userinfo.json" }
  ],
  "tests": [
    {
      "name": "Full flow: OAuth login then create post then verify",
      "description": "Logs in via mocked OAuth, uses the session token for authenticated requests, creates content, verifies in DB and public feed",
      "steps": [
        {
          "name": "OAuth callback to get session token",
          "action": {
            "type": "httpRequest",
            "method": "GET",
            "url": "api-service/auth/callback?code=test_code&state=test"
          },
          "extract": {
            "sessionToken": "$.body.token",
            "userId": "$.body.user.id"
          },
          "assertions": [
            {
              "assertions": [
                { "path": "response.status", "operator": "eq", "value": 200 },
                { "path": "response.body.token", "operator": "exists" }
              ]
            }
          ]
        },
        {
          "name": "GET /api/profile with session token",
          "action": {
            "type": "httpRequest",
            "method": "GET",
            "url": "api-service/api/profile",
            "headers": {
              "Authorization": "Bearer {{sessionToken}}"
            }
          },
          "assertions": [
            {
              "assertions": [
                { "path": "response.status", "operator": "eq", "value": 200 },
                {
                  "path": "response.body.profile.email",
                  "operator": "eq",
                  "value": "bob@example.com"
                },
                {
                  "path": "response.body.profile.name",
                  "operator": "eq",
                  "value": "Bob Smith"
                },
                {
                  "path": "response.body.profile.posts",
                  "operator": "length",
                  "value": 0
                }
              ]
            },
            {
              "service": "api-service",
              "consoleAssertions": [
                {
                  "message": {
                    "operator": "contains",
                    "value": "Authenticated user: bob@example.com"
                  },
                  "count": { "operator": "gte", "value": 1 }
                }
              ]
            }
          ]
        },
        {
          "name": "Create a post as authenticated user",
          "action": {
            "type": "httpRequest",
            "method": "POST",
            "url": "api-service/api/profile/posts",
            "headers": {
              "Authorization": "Bearer {{sessionToken}}",
              "Content-Type": "application/json"
            },
            "body": {
              "title": "My First Post",
              "content": "Written by an OAuth-authenticated user"
            }
          },
          "extract": {
            "postId": "$.body.post.id"
          },
          "assertions": [
            {
              "assertions": [
                { "path": "response.status", "operator": "eq", "value": 201 },
                {
                  "path": "response.body.post.title",
                  "operator": "eq",
                  "value": "My First Post"
                },
                {
                  "path": "response.body.post.published",
                  "operator": "eq",
                  "value": true
                },
                {
                  "path": "response.body.post.authorId",
                  "operator": "eq",
                  "value": "{{userId}}"
                }
              ]
            }
          ]
        },
        {
          "name": "Post appears in public feed",
          "action": {
            "type": "httpRequest",
            "method": "GET",
            "url": "api-service/api/posts"
          },
          "assertions": [
            {
              "assertions": [
                { "path": "response.status", "operator": "eq", "value": 200 },
                {
                  "path": "response.body.posts",
                  "operator": "length",
                  "value": 3
                }
              ]
            }
          ]
        },
        {
          "name": "Post is in the database with correct author",
          "action": {
            "type": "dbQuery",
            "database": "postgres-db",
            "query": "SELECT p.*, u.email as author_email FROM posts p JOIN users u ON p.author_id = u.id WHERE p.id = '{{postId}}'"
          },
          "assertions": [
            {
              "assertions": [
                { "path": "success", "operator": "eq", "value": true },
                {
                  "path": "data[0].title",
                  "operator": "eq",
                  "value": "My First Post"
                },
                {
                  "path": "data[0].author_email",
                  "operator": "eq",
                  "value": "bob@example.com"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "name": "Protected endpoints reject without token",
      "steps": [
        {
          "name": "GET /api/profile with no auth",
          "action": {
            "type": "httpRequest",
            "method": "GET",
            "url": "api-service/api/profile"
          },
          "assertions": [
            {
              "assertions": [
                { "path": "response.status", "operator": "eq", "value": 401 },
                {
                  "path": "response.body.message",
                  "operator": "contains",
                  "value": "Missing or invalid authorization header"
                }
              ]
            }
          ]
        },
        {
          "name": "POST /api/profile/posts with no auth",
          "action": {
            "type": "httpRequest",
            "method": "POST",
            "url": "api-service/api/profile/posts",
            "headers": { "Content-Type": "application/json" },
            "body": { "title": "Nope", "content": "Should fail" }
          },
          "assertions": [
            {
              "assertions": [
                { "path": "response.status", "operator": "eq", "value": 401 }
              ]
            }
          ]
        },
        {
          "name": "No posts created by rejected requests",
          "action": {
            "type": "dbQuery",
            "database": "postgres-db",
            "query": "SELECT COUNT(*) as count FROM posts"
          },
          "assertions": [
            {
              "assertions": [
                { "path": "data[0].count", "operator": "eq", "value": 4 }
              ]
            }
          ]
        }
      ]
    },
    {
      "name": "Protected endpoints reject invalid token",
      "steps": [
        {
          "name": "GET /api/profile with fake token",
          "action": {
            "type": "httpRequest",
            "method": "GET",
            "url": "api-service/api/profile",
            "headers": {
              "Authorization": "Bearer totally.fake.token"
            }
          },
          "assertions": [
            {
              "assertions": [
                { "path": "response.status", "operator": "eq", "value": 401 },
                {
                  "path": "response.body.message",
                  "operator": "eq",
                  "value": "Invalid session token"
                }
              ]
            },
            {
              "service": "api-service",
              "consoleAssertions": [
                {
                  "message": {
                    "operator": "contains",
                    "value": "Invalid session token"
                  },
                  "count": { "operator": "gte", "value": 1 }
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
