{
  "name": "profile-posts-visibility",
  "description": "Tests that a user's profile correctly reflects their posts — new posts appear in the profile and the public feed, while another user's posts are excluded from the profile",
  "items": [
    {
      "$ref": "../shared/api-service.json"
    },
    {
      "$ref": "../shared/postgres-db.json",
      "initFilePath": "../init-files/schema.sql"
    },
    {
      "$ref": "../shared/mock-oauth-token.json"
    },
    {
      "$ref": "../shared/mock-oauth-userinfo.json"
    }
  ],
  "tests": [
    {
      "name": "New user profile starts empty then accumulates posts",
      "description": "Bob logs in via OAuth (new user), creates two posts, and verifies the profile reflects them. Alice's seed posts should not appear in Bob's profile.",
      "steps": [
        {
          "name": "OAuth login to get session token",
          "action": {
            "type": "httpRequest",
            "method": "GET",
            "url": "api-service/auth/callback?code=test_code&state=s1"
          },
          "extract": {
            "sessionToken": "$.response.body.token",
            "userId": "$.response.body.user.id"
          },
          "assertions": [
            {
              "assertions": [
                {
                  "path": "$.response.status",
                  "operator": "eq",
                  "value": 200
                }
              ]
            }
          ]
        },
        {
          "name": "Profile starts with zero posts",
          "action": {
            "type": "httpRequest",
            "method": "GET",
            "url": "api-service/api/profile",
            "headers": {
              "Authorization": "Bearer {{sessionToken}}"
            }
          },
          "assertions": [
            {
              "assertions": [
                {
                  "path": "$.response.status",
                  "operator": "eq",
                  "value": 200
                },
                {
                  "count": "$.response.body.profile.posts",
                  "operator": "eq",
                  "value": 0
                }
              ]
            }
          ]
        },
        {
          "name": "Create post: {{post.title}}",
          "forEach": {
            "items": [
              { "title": "First Post", "content": "Hello world" },
              { "title": "Second Post", "content": "More content" }
            ],
            "as": "post",
            "action": {
              "type": "httpRequest",
              "method": "POST",
              "url": "api-service/api/profile/posts",
              "headers": {
                "Authorization": "Bearer {{sessionToken}}",
                "Content-Type": "application/json"
              },
              "body": {
                "title": "{{post.title}}",
                "content": "{{post.content}}"
              }
            },
            "assertions": [
              {
                "assertions": [
                  {
                    "path": "$.response.status",
                    "operator": "eq",
                    "value": 201
                  },
                  {
                    "path": "$.response.body.post.authorId",
                    "operator": "eq",
                    "value": "{{userId}}"
                  }
                ]
              }
            ]
          }
        },
        {
          "name": "Profile now shows exactly 2 posts",
          "action": {
            "type": "httpRequest",
            "method": "GET",
            "url": "api-service/api/profile",
            "headers": {
              "Authorization": "Bearer {{sessionToken}}"
            }
          },
          "assertions": [
            {
              "assertions": [
                {
                  "path": "$.response.status",
                  "operator": "eq",
                  "value": 200
                },
                {
                  "count": "$.response.body.profile.posts",
                  "operator": "eq",
                  "value": 2
                }
              ]
            }
          ]
        },
        {
          "name": "Public feed has 4 posts total (2 seed + 2 new)",
          "action": {
            "type": "httpRequest",
            "method": "GET",
            "url": "api-service/api/posts"
          },
          "assertions": [
            {
              "assertions": [
                {
                  "path": "$.response.status",
                  "operator": "eq",
                  "value": 200
                },
                {
                  "count": "$.response.body.posts",
                  "operator": "eq",
                  "value": 4
                }
              ]
            }
          ]
        },
        {
          "name": "DB confirms Bob owns exactly 2 posts",
          "action": {
            "type": "dbQuery",
            "database": "postgres-db",
            "query": "SELECT COUNT(*) as count FROM posts WHERE author_id = '{{userId}}'"
          },
          "assertions": [
            {
              "assertions": [
                {
                  "path": "$.response.data[0].count",
                  "operator": "eq",
                  "value": 2
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
