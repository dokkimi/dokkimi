{
  "name": "oauth-redirect-flow",
  "description": "Tests every endpoint in the OAuth redirect flow independently — login redirect, callback with mocked token exchange and userinfo, and auth rejection",
  "items": [
    {
      "$ref": "../shared/api-service.json"
    },
    {
      "$ref": "../shared/postgres-db.json",
      "initFilePath": "../init-files/schema.sql"
    },
    {
      "$ref": "../shared/mock-oauth-token.json"
    },
    {
      "$ref": "../shared/mock-oauth-userinfo.json"
    }
  ],
  "variables": {
    "oauthDomain": "auth.provider.com",
    "clientId": "demo-client-id"
  },
  "tests": [
    {
      "name": "GET /auth/login redirects to OAuth provider",
      "description": "Verifies the redirect URL has the correct client_id, redirect_uri, scope, and response_type",
      "steps": [
        {
          "name": "Hit login endpoint",
          "action": {
            "type": "httpRequest",
            "method": "GET",
            "url": "api-service/auth/login"
          },
          "assertions": [
            {
              "assertions": [
                {
                  "path": "$.response.status",
                  "operator": "eq",
                  "value": 302
                },
                {
                  "path": "$.response.headers.location",
                  "operator": "contains",
                  "value": "https://{{oauthDomain}}/authorize"
                },
                {
                  "path": "$.response.headers.location",
                  "operator": "contains",
                  "value": "client_id={{clientId}}"
                },
                {
                  "path": "$.response.headers.location",
                  "operator": "contains",
                  "value": "response_type=code"
                },
                {
                  "path": "$.response.headers.location",
                  "operator": "contains",
                  "value": "scope=openid+profile+email"
                },
                {
                  "path": "$.response.headers.location",
                  "operator": "contains",
                  "value": "redirect_uri="
                }
              ]
            },
            {
              "service": "api-service",
              "consoleAssertions": [
                {
                  "message": {
                    "operator": "contains",
                    "value": "Redirecting to OAuth provider"
                  },
                  "count": {
                    "operator": "eq",
                    "value": 1
                  }
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "name": "GET /auth/callback exchanges code and creates user",
      "description": "Simulates the OAuth provider redirecting back with a code. The service exchanges it for a token (mocked), fetches userinfo (mocked), and creates the user in the DB.",
      "variables": {
        "mockCode": "auth_code_xyz789"
      },
      "steps": [
        {
          "name": "Hit callback with authorization code",
          "action": {
            "type": "httpRequest",
            "method": "GET",
            "url": "api-service/auth/callback?code={{mockCode}}&state=test-state"
          },
          "extract": {
            "sessionToken": "$.response.body.token",
            "userId": "$.response.body.user.id"
          },
          "assertions": [
            {
              "assertions": [
                {
                  "path": "$.response.status",
                  "operator": "eq",
                  "value": 200
                },
                {
                  "path": "$.response.body.token",
                  "operator": "exists"
                },
                {
                  "path": "$.response.body.user.email",
                  "operator": "eq",
                  "value": "bob@example.com"
                },
                {
                  "path": "$.response.body.user.name",
                  "operator": "eq",
                  "value": "Bob Smith"
                }
              ]
            },
            {
              "match": {
                "origin": "api-service",
                "method": "POST",
                "url": "{{oauthDomain}}/oauth/token"
              },
              "count": {
                "operator": "eq",
                "value": 1
              },
              "assertions": [
                {
                  "path": "$.request.body.grant_type",
                  "operator": "eq",
                  "value": "authorization_code"
                },
                {
                  "path": "$.request.body.code",
                  "operator": "eq",
                  "value": "{{mockCode}}"
                },
                {
                  "path": "$.request.body.client_id",
                  "operator": "eq",
                  "value": "{{clientId}}"
                },
                {
                  "path": "$.request.body.client_secret",
                  "operator": "exists"
                },
                {
                  "path": "$.request.body.redirect_uri",
                  "operator": "exists"
                },
                {
                  "path": "$.response.status",
                  "operator": "eq",
                  "value": 200
                },
                {
                  "path": "$.response.body.access_token",
                  "operator": "exists"
                }
              ]
            },
            {
              "match": {
                "origin": "api-service",
                "method": "GET",
                "url": "{{oauthDomain}}/userinfo"
              },
              "count": {
                "operator": "eq",
                "value": 1
              },
              "assertions": [
                {
                  "path": "$.request.headers.authorization",
                  "operator": "eq",
                  "value": "Bearer mock_access_token_abc123"
                },
                {
                  "path": "$.response.status",
                  "operator": "eq",
                  "value": 200
                },
                {
                  "path": "$.response.body.email",
                  "operator": "eq",
                  "value": "bob@example.com"
                }
              ]
            },
            {
              "service": "api-service",
              "consoleAssertions": [
                {
                  "message": {
                    "operator": "contains",
                    "value": "Exchanging authorization code"
                  },
                  "count": {
                    "operator": "gte",
                    "value": 1
                  }
                },
                {
                  "message": {
                    "operator": "contains",
                    "value": "Token exchange successful"
                  },
                  "count": {
                    "operator": "gte",
                    "value": 1
                  }
                },
                {
                  "message": {
                    "operator": "contains",
                    "value": "Fetching user info"
                  },
                  "count": {
                    "operator": "gte",
                    "value": 1
                  }
                },
                {
                  "message": {
                    "operator": "contains",
                    "value": "Creating new user"
                  },
                  "count": {
                    "operator": "eq",
                    "value": 1
                  }
                },
                {
                  "message": {
                    "operator": "contains",
                    "value": "OAuth flow complete"
                  },
                  "count": {
                    "operator": "gte",
                    "value": 1
                  }
                }
              ]
            }
          ]
        },
        {
          "name": "Verify user was created in database",
          "action": {
            "type": "dbQuery",
            "database": "postgres-db",
            "query": "SELECT * FROM users WHERE oauth_id = 'oauth_user_bob'"
          },
          "assertions": [
            {
              "assertions": [
                {
                  "path": "$.response.success",
                  "operator": "eq",
                  "value": true
                },
                {
                  "path": "$.response.data",
                  "operator": "length",
                  "value": 1
                },
                {
                  "path": "$.response.data[0].email",
                  "operator": "eq",
                  "value": "bob@example.com"
                },
                {
                  "path": "$.response.data[0].name",
                  "operator": "eq",
                  "value": "Bob Smith"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "name": "GET /auth/callback without code returns 401",
      "steps": [
        {
          "name": "Callback with no code param",
          "action": {
            "type": "httpRequest",
            "method": "GET",
            "url": "api-service/auth/callback"
          },
          "assertions": [
            {
              "assertions": [
                {
                  "path": "$.response.status",
                  "operator": "eq",
                  "value": 401
                },
                {
                  "path": "$.response.body.message",
                  "operator": "contains",
                  "value": "Missing authorization code"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "name": "Repeated OAuth login is idempotent",
      "description": "Two logins with different authorization codes both hit the OAuth provider (new code = new token exchange), but only one user is created in the DB",
      "steps": [
        {
          "name": "First login",
          "action": {
            "type": "httpRequest",
            "method": "GET",
            "url": "api-service/auth/callback?code=first_code&state=s1"
          },
          "extract": {
            "firstUserId": "$.response.body.user.id"
          },
          "assertions": [
            {
              "assertions": [
                {
                  "path": "$.response.status",
                  "operator": "eq",
                  "value": 200
                },
                {
                  "path": "$.response.body.user.email",
                  "operator": "eq",
                  "value": "bob@example.com"
                }
              ]
            }
          ]
        },
        {
          "name": "Second login with a different code",
          "action": {
            "type": "httpRequest",
            "method": "GET",
            "url": "api-service/auth/callback?code=second_code&state=s2"
          },
          "extract": {
            "secondUserId": "$.response.body.user.id"
          },
          "assertions": [
            {
              "assertions": [
                {
                  "path": "$.response.status",
                  "operator": "eq",
                  "value": 200
                },
                {
                  "path": "$.response.body.user.id",
                  "operator": "eq",
                  "value": "{{firstUserId}}"
                },
                {
                  "path": "$.response.body.user.email",
                  "operator": "eq",
                  "value": "bob@example.com"
                }
              ]
            },
            {
              "match": {
                "origin": "api-service",
                "method": "POST",
                "url": "{{oauthDomain}}/oauth/token"
              },
              "count": {
                "operator": "eq",
                "value": 1
              },
              "assertions": [
                {
                  "path": "$.request.body.grant_type",
                  "operator": "eq",
                  "value": "authorization_code"
                }
              ]
            },
            {
              "match": {
                "origin": "api-service",
                "method": "GET",
                "url": "{{oauthDomain}}/userinfo"
              },
              "count": {
                "operator": "eq",
                "value": 1
              }
            },
            {
              "service": "api-service",
              "consoleAssertions": [
                {
                  "message": {
                    "operator": "contains",
                    "value": "Found existing user"
                  },
                  "count": {
                    "operator": "gte",
                    "value": 1
                  }
                }
              ]
            }
          ]
        },
        {
          "name": "Only one user in the database despite two logins",
          "action": {
            "type": "dbQuery",
            "database": "postgres-db",
            "query": "SELECT COUNT(*) as count FROM users WHERE oauth_id = 'oauth_user_bob'"
          },
          "assertions": [
            {
              "assertions": [
                {
                  "path": "$.response.data[0].count",
                  "operator": "eq",
                  "value": 1
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
