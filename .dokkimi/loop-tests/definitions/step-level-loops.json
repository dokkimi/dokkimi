{
  "name": "step-level-loops",
  "description": "Validates all three loop modifiers at the step level",
  "items": [
    { "$ref": "../shared/api-service.json" },
    {
      "$ref": "../shared/postgres-db.json",
      "initFilePath": "../init-files/schema.sql"
    },
    { "$ref": "../../demo-oauth-flow/shared/mock-oauth-token.json" },
    { "$ref": "../../demo-oauth-flow/shared/mock-oauth-userinfo.json" }
  ],
  "tests": [
    {
      "name": "forEach with inline data (create multiple posts)",
      "steps": [
        {
          "name": "Login to get session token",
          "action": {
            "type": "httpRequest",
            "method": "GET",
            "url": "api-service/auth/callback?code=test_code&state=s1"
          },
          "extract": {
            "sessionToken": "$.response.body.token"
          }
        },
        {
          "name": "Create post: {{post.title}}",
          "forEach": {
            "items": [
              { "title": "First Post", "content": "Hello world" },
              { "title": "Second Post", "content": "More content" },
              { "title": "Third Post", "content": "Even more" }
            ],
            "as": "post",
            "action": {
              "type": "httpRequest",
              "method": "POST",
              "url": "api-service/api/profile/posts",
              "headers": {
                "Authorization": "Bearer {{sessionToken}}",
                "Content-Type": "application/json"
              },
              "body": {
                "title": "{{post.title}}",
                "content": "{{post.content}}"
              }
            },
            "assertions": [
              {
                "assertions": [
                  {
                    "path": "$.response.status",
                    "operator": "eq",
                    "value": 201
                  }
                ]
              }
            ]
          }
        },
        {
          "name": "Verify all 3 new posts exist in profile",
          "action": {
            "type": "httpRequest",
            "method": "GET",
            "url": "api-service/api/profile",
            "headers": {
              "Authorization": "Bearer {{sessionToken}}"
            }
          },
          "assertions": [
            {
              "assertions": [
                { "path": "$.response.status", "operator": "eq", "value": 200 },
                {
                  "count": "$.response.body.profile.posts",
                  "operator": "eq",
                  "value": 3
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "name": "forEach with extracted array from DB",
      "steps": [
        {
          "name": "Get seed posts from DB",
          "action": {
            "type": "dbQuery",
            "database": "postgres-db",
            "query": "SELECT id, title FROM posts WHERE author_id = 'a1b2c3d4-0000-0000-0000-000000000001' AND published = true"
          },
          "extract": {
            "posts": "$.response.data"
          },
          "assertions": [
            {
              "assertions": [
                {
                  "path": "$.response.success",
                  "operator": "eq",
                  "value": true
                },
                { "count": "$.response.data", "operator": "eq", "value": 2 }
              ]
            }
          ]
        },
        {
          "name": "Verify post {{post.title}} via API",
          "forEach": {
            "items": "{{posts}}",
            "as": "post",
            "action": {
              "type": "httpRequest",
              "method": "GET",
              "url": "api-service/api/posts/{{post.id}}"
            },
            "assertions": [
              {
                "assertions": [
                  {
                    "path": "$.response.status",
                    "operator": "eq",
                    "value": 200
                  },
                  {
                    "path": "$.response.body.title",
                    "operator": "eq",
                    "value": "{{post.title}}"
                  }
                ]
              }
            ]
          }
        }
      ]
    },
    {
      "name": "for loop with numeric range (seed posts via DB)",
      "steps": [
        {
          "name": "Insert post {{i}} via DB",
          "for": {
            "from": 1,
            "to": 3,
            "as": "i",
            "assertions": [
              {
                "assertions": [
                  {
                    "path": "$.response.success",
                    "operator": "eq",
                    "value": true
                  }
                ]
              }
            ]
          },
          "action": {
            "type": "dbQuery",
            "database": "postgres-db",
            "query": "INSERT INTO posts (title, content, published, author_id) VALUES ('Loop Post {{i}}', 'Content {{i}}', true, 'a1b2c3d4-0000-0000-0000-000000000001') RETURNING id"
          }
        },
        {
          "name": "Verify all 3 loop-inserted posts exist",
          "action": {
            "type": "dbQuery",
            "database": "postgres-db",
            "query": "SELECT COUNT(*)::int as count FROM posts WHERE title LIKE 'Loop Post%'"
          },
          "assertions": [
            {
              "assertions": [
                {
                  "path": "$.response.success",
                  "operator": "eq",
                  "value": true
                },
                {
                  "path": "$.response.data[0].count",
                  "operator": "eq",
                  "value": 3
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "name": "repeat with until — polls and exits early",
      "steps": [
        {
          "name": "Poll health endpoint until status 200 (attempt {{attempt}})",
          "repeat": {
            "count": 5,
            "as": "attempt",
            "name": "pollLoop",
            "delayMs": 100,
            "until": [
              {
                "path": "$.response.status",
                "operator": "eq",
                "value": 200
              }
            ]
          },
          "stopOnFailure": false,
          "action": {
            "type": "httpRequest",
            "method": "GET",
            "url": "api-service/health"
          }
        },
        {
          "name": "Verify loop completed via until",
          "action": {
            "type": "wait",
            "durationMs": 10
          },
          "assertions": [
            {
              "assertions": [
                {
                  "path": "$.variables.pollLoop.completed",
                  "operator": "eq",
                  "value": true
                },
                {
                  "path": "$.variables.pollLoop.iterations",
                  "operator": "lte",
                  "value": 5
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "name": "repeat without until — simple count-based",
      "steps": [
        {
          "name": "Hit health endpoint 3 times",
          "repeat": {
            "count": 3,
            "as": "round",
            "name": "roundLoop",
            "assertions": [
              {
                "assertions": [
                  {
                    "path": "$.response.status",
                    "operator": "eq",
                    "value": 200
                  }
                ]
              }
            ]
          },
          "action": {
            "type": "httpRequest",
            "method": "GET",
            "url": "api-service/health"
          }
        },
        {
          "name": "Verify all 3 iterations ran",
          "action": {
            "type": "wait",
            "durationMs": 10
          },
          "assertions": [
            {
              "assertions": [
                {
                  "path": "$.variables.roundLoop.iterations",
                  "operator": "eq",
                  "value": 3
                },
                {
                  "path": "$.variables.roundLoop.completed",
                  "operator": "eq",
                  "value": true
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "name": "repeat with unsatisfiable until — exhausts count",
      "steps": [
        {
          "name": "Poll for nonexistent post (attempt {{attempt}})",
          "repeat": {
            "count": 3,
            "as": "attempt",
            "name": "exhaustLoop",
            "delayMs": 50,
            "until": [
              {
                "path": "$.response.data[0].count",
                "operator": "gte",
                "value": 9999
              }
            ]
          },
          "stopOnFailure": false,
          "action": {
            "type": "dbQuery",
            "database": "postgres-db",
            "query": "SELECT COUNT(*)::int as count FROM posts WHERE title = 'THIS_DOES_NOT_EXIST'"
          }
        },
        {
          "name": "Verify loop did NOT complete (until never matched)",
          "action": {
            "type": "wait",
            "durationMs": 10
          },
          "assertions": [
            {
              "assertions": [
                {
                  "path": "$.variables.exhaustLoop.completed",
                  "operator": "eq",
                  "value": false
                },
                {
                  "path": "$.variables.exhaustLoop.iterations",
                  "operator": "eq",
                  "value": 3
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
