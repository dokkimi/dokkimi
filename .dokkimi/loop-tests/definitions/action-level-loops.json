{
  "name": "action-level-loops",
  "description": "Validates loop modifiers at the action level — loops only the action, extract+assertions run once after",
  "items": [
    { "$ref": "../shared/api-service.json" },
    {
      "$ref": "../shared/postgres-db.json",
      "initFilePath": "../init-files/schema.sql"
    },
    { "$ref": "../../demo-oauth-flow/shared/mock-oauth-token.json" },
    { "$ref": "../../demo-oauth-flow/shared/mock-oauth-userinfo.json" }
  ],
  "tests": [
    {
      "name": "Action-level for: seed posts via DB then verify last response",
      "steps": [
        {
          "name": "Insert 3 posts via action loop",
          "action": {
            "type": "dbQuery",
            "database": "postgres-db",
            "query": "INSERT INTO posts (title, content, published, author_id) VALUES ('Action Post {{i}}', 'Content {{i}}', true, 'a1b2c3d4-0000-0000-0000-000000000001') RETURNING id",
            "for": { "from": 1, "to": 3, "as": "i" }
          },
          "assertions": [
            {
              "assertions": [
                { "path": "$.response.success", "operator": "eq", "value": true }
              ]
            }
          ]
        },
        {
          "name": "Verify posts were created",
          "action": {
            "type": "dbQuery",
            "database": "postgres-db",
            "query": "SELECT COUNT(*)::int as count FROM posts WHERE title LIKE 'Action Post%'"
          },
          "assertions": [
            {
              "assertions": [
                {
                  "path": "$.response.data[0].count",
                  "operator": "eq",
                  "value": 3
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "name": "Action-level forEach: fetch multiple posts by ID",
      "steps": [
        {
          "name": "Get published post IDs from DB",
          "action": {
            "type": "dbQuery",
            "database": "postgres-db",
            "query": "SELECT id FROM posts WHERE published = true LIMIT 2"
          },
          "extract": {
            "postIds": "$.response.data"
          }
        },
        {
          "name": "Fetch each post via API",
          "action": {
            "type": "httpRequest",
            "method": "GET",
            "url": "api-service/api/posts/{{postEntry.id}}",
            "forEach": {
              "items": "{{postIds}}",
              "as": "postEntry",
              "delayMs": 50
            }
          },
          "assertions": [
            {
              "assertions": [
                { "path": "$.response.status", "operator": "eq", "value": 200 }
              ]
            }
          ]
        }
      ]
    },
    {
      "name": "Action-level repeat with until on DB query",
      "steps": [
        {
          "name": "Poll post count until seed data is present",
          "action": {
            "type": "dbQuery",
            "database": "postgres-db",
            "query": "SELECT COUNT(*)::int as count FROM posts WHERE published = true",
            "repeat": {
              "count": 5,
              "as": "poll",
              "delayMs": 100,
              "until": [
                {
                  "path": "$.response.data[0].count",
                  "operator": "gte",
                  "value": 2
                }
              ]
            }
          },
          "assertions": [
            {
              "assertions": [
                { "path": "$.response.success", "operator": "eq", "value": true }
              ]
            }
          ]
        }
      ]
    }
  ]
}
