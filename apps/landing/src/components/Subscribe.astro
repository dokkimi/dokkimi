---

<section id="subscribe" class="subscribe">
  <div class="container">
    <h2 class="section-heading">Stay in the loop</h2>
    <p class="section-subtitle">
      New features, tutorials, and tips every two weeks. No spam.
    </p>
    <form
      action="https://buttondown.com/api/emails/embed-subscribe/dokkimi"
      method="post"
      class="subscribe-form"
      id="newsletter-form"
    >
      <input type="email" name="email" placeholder="you@example.com" required />
      <button type="submit">Subscribe</button>
    </form>
  </div>
</section>

<script is:inline>
  (function () {
    var form = document.getElementById('newsletter-form');
    if (!form) return;
    form.addEventListener('submit', function (e) {
      // Intercept so the GA4 event is recorded before the form POSTs to
      // Buttondown and the page navigates away (avoids the lost-event race).
      e.preventDefault();
      var submitted = false;
      function submitForm() {
        if (submitted) return;
        submitted = true;
        form.submit();
      }
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({
        event: 'newsletter_subscribe',
        form_location: 'subscribe_section',
        eventCallback: submitForm, // submit once GTM has fired the tag
        eventTimeout: 1000,
      });
      // Fallback: if GTM is blocked/absent, submit anyway after 1s.
      setTimeout(submitForm, 1000);
    });
  })();
</script>

<style>
  .subscribe {
    padding: var(--section-spacing) 0;
  }

  .subscribe-form {
    display: flex;
    gap: 12px;
    justify-content: center;
    max-width: 440px;
    margin: 0 auto;
  }

  .subscribe-form input {
    flex: 1;
    padding: 12px 16px;
    background: var(--color-bg-soft);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    color: var(--color-text);
    font-family: var(--font-sans);
    font-size: 0.925rem;
    outline: none;
    transition: border-color 0.2s;
  }

  .subscribe-form input::placeholder {
    color: var(--color-text-muted);
  }

  .subscribe-form input:focus {
    border-color: var(--color-primary);
  }

  .subscribe-form button {
    padding: 12px 24px;
    background: var(--color-primary);
    border: 1px solid var(--color-primary);
    border-radius: 8px;
    color: white;
    font-family: var(--font-sans);
    font-size: 0.925rem;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s;
    white-space: nowrap;
  }

  .subscribe-form button:hover {
    background: var(--color-primary-soft);
    border-color: var(--color-primary-soft);
  }

  @media (max-width: 480px) {
    .subscribe-form {
      flex-direction: column;
    }
  }
</style>
