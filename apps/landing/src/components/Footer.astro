<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-left">
      <span class="logo"><img src="/logo-teal.png" alt="Dokkimi" class="footer-logo" />Dokkimi</span>
      <p>Integration, E2E, and visual regression testing.</p>
    </div>
    <div class="footer-links">
      <div class="link-group">
        <h4>Product</h4>
        <a href="/#features">Features</a>
        <a href="/#pricing">Pricing</a>
        <a href="/docs">Docs</a>
        <a href="/tutorials">Tutorials</a>
      </div>
      <div class="link-group">
        <h4>Resources</h4>
        <a href="/blog">Blog</a>
        <a href="https://www.npmjs.com/package/dokkimi" target="_blank" rel="noopener noreferrer">npm</a>
        <a href="https://github.com/dokkimi/dokkimi/discussions" target="_blank" rel="noopener noreferrer">Community</a>
      </div>
      <div class="link-group">
        <h4>Connect</h4>
        <a href="https://github.com/dokkimi/dokkimi" target="_blank" rel="noopener noreferrer" class="icon-link">
