---
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'The only testing framework that does integration, E2E, and visual regression testing. All without a staging environment.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Consent Mode v2 defaults — must run before GTM loads -->
      <script>
        window.dataLayer = window.dataLayer || [];
        function gtag() { dataLayer.push(arguments); }
        gtag('consent', 'default', {
          analytics_storage:     'denied',
          ad_storage:            'denied',
          ad_user_data:          'denied',
          ad_personalization:    'denied',
          functionality_storage: 'granted',
          security_storage:      'granted'
        });
      </script>

      <!-- Cookie consent manager -->
      <link rel="stylesheet" href="/assets/consent-manager/cookieconsent.css" />
      <script src="/assets/consent-manager/cookieconsent.umd.js"></script>

      <!-- Consent manager init -->
      <script>
        CookieConsent.run({
          guiOptions: {
            consentModal: { layout: 'bar', position: 'bottom' }
          },
          categories: {
            necessary: { enabled: true, readOnly: true },
            analytics: {
              autoClear: { cookies: [{ name: /^_ga/ }, { name: '_gid' }] },
              services: {
                ga4: {
                  label: 'Google Analytics',
                  onAccept: () => gtag('consent', 'update', { analytics_storage: 'granted' }),
                  onReject: () => gtag('consent', 'update', { analytics_storage: 'denied' })
                }
              }
            }
          },
          language: {
            default: 'en',
            translations: {
              en: {
                consentModal: {
                  title: 'We use cookies',
                  description: 'Analytics cookies help us understand how the site is used. No ads, no tracking beyond that.',
                  acceptAllBtn: 'Accept',
                  rejectAllBtn: 'Decline',
                  showPreferencesBtn: 'Manage preferences'
                },
                preferencesModal: {
                  title: 'Cookie preferences',
                  acceptAllBtn: 'Accept all',
                  rejectAllBtn: 'Reject all',
                  savePreferencesBtn: 'Save',
                  sections: [
                    { title: 'Essential', description: 'Required for the site to work.', linkedCategory: 'necessary' },
                    { title: 'Analytics', description: 'Helps us understand traffic and improve the site. Uses Google Analytics.', linkedCategory: 'analytics' }
                  ]
                }
              }
            }
          }
        });
      </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:image" content="https://dokkimi.com/og-image.png" />

    <link rel="canonical" href={Astro.url.href} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://dokkimi.com/og-image.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

    <link rel="icon" href="/logo-teal.png" type="image/png" />
    <link rel="preload" href="/logo-teal.png" as="image" />

    <title>{title}</title>

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "Dokkimi",
      "applicationCategory": "DeveloperApplication",
      "operatingSystem": "macOS, Linux",
      "description": description,
      "url": "https://dokkimi.com",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD",
      },
    })} />
  </head>
  <body>
    <slot />
    <Analytics />
  </body>
</html>
