  <h3>Step response — HTTP</h3>
  <table>
    <thead>
      <tr><th>Path</th><th>Description</th></tr>
    </thead>
    <tbody>
      <tr><td><code>$.response.status</code></td><td>HTTP status code (integer)</td></tr>
      <tr><td><code>$.response.body</code></td><td>Entire response body</td></tr>
