      <tr><td><code>$.response.data</code></td><td>Array of result rows</td></tr>
      <tr><td><code>$.response.data[0].column</code></td><td>Specific column from a result row</td></tr>
      <tr><td><code>$.response.rowsAffected</code></td><td>Number of affected rows (integer)</td></tr>
      <tr><td><code>$.response.error</code></td><td>Error message if query failed</td></tr>
