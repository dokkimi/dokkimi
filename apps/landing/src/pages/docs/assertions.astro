      <tr><td><code>$.request.body</code></td><td>Entire request body</td></tr>
      <tr><td><code>$.request.body.field</code></td><td>Field in request body</td></tr>
      <tr><td><code>$.request.headers.header-name</code></td><td>Request header (case-insensitive)</td></tr>
      <tr><td><code>$.responseTime</code></td><td>Response time in milliseconds</td></tr>
    </tbody>
  </table>

  <h3>Step response — Database query</h3>
