  <Nav />
  <main>
    <Hero />
    <GetStarted />
    <BuiltForAI />
    <Features />
    <Coverage />
    <HowItWorks />
    <LearnMore />
    <Pricing />
    <Subscribe />
  </main>
  <Footer />
</BaseLayout>
